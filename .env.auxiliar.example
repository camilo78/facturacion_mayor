# ─────────────────────────────────────────────
#  Factunet — Configuración del nodo Auxiliar
# ─────────────────────────────────────────────
#  Copia este archivo a .env y completa los
#  valores marcados con <COMPLETAR>.
# ─────────────────────────────────────────────

APP_NAME="Factunet Auxiliar"
APP_ENV=production
APP_KEY=                        # Generar con: php artisan key:generate
APP_DEBUG=false
APP_URL=http://localhost
APP_PORT=80                     # Puerto local del contenedor nginx

APP_LOCALE=es
APP_TIMEZONE=America/Tegucigalpa

LOG_CHANNEL=daily
LOG_LEVEL=warning

# ── Base de datos ──────────────────────────────
DB_CONNECTION=mariadb
DB_HOST=db                      # Nombre del servicio en docker-compose
DB_PORT=3306
DB_DATABASE=auxiliar_landlord   # Base central (landlord) del Auxiliar
DB_USERNAME=auxiliar
DB_PASSWORD=<COMPLETAR>
DB_ROOT_PASSWORD=<COMPLETAR>    # Solo para docker-compose / healthcheck

# ── Drivers sin Redis ──────────────────────────
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=480

# ── Instancia Auxiliar ─────────────────────────
INSTANCE_MODE=auxiliar
INSTANCE_UUID=<COMPLETAR>       # UUID generado por: php artisan instance:registrar en el Mayor
INSTANCE_LABEL="Auxiliar — Casa Matriz"

# ── Conexión con el Mayor ──────────────────────
MAYOR_SYNC_URL=<COMPLETAR>      # Ej: https://factunet.io
MAYOR_SYNC_TOKEN=<COMPLETAR>    # Token generado por: php artisan instance:registrar en el Mayor

# ── Tenancy (stancl/tenancy) ───────────────────
TENANCY_DATABASE_MANAGER=mariadb
